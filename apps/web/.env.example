# Copy to .env.local and fill in. Everything is optional — Clutch runs fully without keys.

# ── AI (provider-agnostic; blank → built-in deterministic engine) ──────────────
# RECOMMENDED: OmniRoute — free, unlimited, OpenAI-compatible local router.
#   npm install -g omniroute && omniroute   (serves http://localhost:20128)
AI_PROVIDER=openai
AI_BASE_URL=http://localhost:20128/v1
AI_MODEL=auto
AI_API_KEY=
# Other OpenAI-compatible options (OpenAI, Groq, OpenRouter, Together, DeepSeek, Ollama):
#   AI_BASE_URL=https://api.groq.com/openai/v1   AI_MODEL=llama-3.3-70b-versatile   AI_API_KEY=gsk_...
#   (omit AI_BASE_URL for OpenAI itself)         AI_MODEL=gpt-4o-mini               AI_API_KEY=sk-...
# For Google Gemini instead:  AI_PROVIDER=gemini  AI_MODEL=gemini-1.5-flash  AI_API_KEY=...

# ── Google Calendar + Gmail (blank → simulated mode) ──────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# ── Microsoft 365 / Outlook calendar + mail (blank → simulated mode) ──────────
# Register an app at https://entra.microsoft.com → App registrations.
# Add the redirect URI below and grant delegated Graph scopes:
#   Calendars.Read, Mail.Read, User.Read, offline_access
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT=common
MS_REDIRECT_URI=http://localhost:3000/api/ms/callback

# ── IMAP (any inbox) ──────────────────────────────────────────────────────────
# No env needed — host/user/app-password are entered in the Import dialog per scan
# and never stored. Requires the optional `imapflow` dependency (already in deps).

# ── Convex (set automatically by `npx convex dev`) ────────────────────────────
# NEXT_PUBLIC_CONVEX_URL=
